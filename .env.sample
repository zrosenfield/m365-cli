# sp-cli environment configuration
# Copy to .env and fill in your values. Never commit .env.

# ── Service principal (recommended for agents / automation) ──────────────────
# Found in Azure AD → App registrations → your app → Overview
SP_CLI_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SP_CLI_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Found in Azure AD → App registrations → your app → Certificates & secrets
SP_CLI_CLIENT_SECRET=your-client-secret-value

# ── SharePoint tenant ────────────────────────────────────────────────────────
# Your SharePoint root URL (no trailing slash)
SP_CLI_TENANT_URL=https://contoso.sharepoint.com

# ── Defaults (optional) ──────────────────────────────────────────────────────
# Avoids needing --site and --drive on every command.
# Get these by running: sp sites list  /  sp drives list --site <id>
SP_CLI_SITE_ID=contoso.sharepoint.com,xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx,xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SP_CLI_DRIVE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Alternative: raw access token ───────────────────────────────────────────
# If you already have a Bearer token (e.g. from another auth system),
# set this and all other auth vars above are ignored.
# SP_CLI_ACCESS_TOKEN=eyJ...
